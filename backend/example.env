# Nombre del proyecto
PROJECT_NAME=Atlas Finance

# Entorno de ejecución: development | test | production
# • development / test → seed_base + seed_demo corren automáticamente.
# • production        → solo seed_base corre (catálogos); seed_demo requiere SEED_DEMO_DATA=true.
ENVIRONMENT=development

# Habilita la carga de datos demo en producción.
# En development/test no es necesario (se activa por ENVIRONMENT).
# Establecer en true solo para demos puntuales en producción.
SEED_DEMO_DATA=false

# Email que se promoverá automáticamente a admin al registrarse,
# únicamente si aún no existe ningún usuario admin.
BOOTSTRAP_ADMIN_EMAIL=

# Prefijo para las rutas de la API
API_V1_PREFIX=/api/v1

# URL de la base de datos
# DEPENDENCIA: usuario, contraseña y nombre de DB deben coincidir con
# POSTGRES_USER, POSTGRES_PASSWORD y POSTGRES_DB del .env raíz.
DATABASE_URL=postgresql+psycopg://atlas:atlas@db:5432/atlas_finance

# Clave secreta para firmar los tokens JWT
SECRET_KEY=super-secret-change-me

# Algoritmo utilizado para los tokens JWT
ALGORITHM=HS256

# Tiempo de expiración del token de acceso (en minutos)
ACCESS_TOKEN_EXPIRE_MINUTES=120

# Tiempo de expiración del refresh token (en minutos)
REFRESH_TOKEN_EXPIRE_MINUTES=1440

# Moneda predeterminada
DEFAULT_CURRENCY=COP

# Origenes permitidos para CORS (separados por coma)
BACKEND_CORS_ORIGINS=http://localhost:8502,http://127.0.0.1:8502,http://localhost:5173,http://127.0.0.1:5173

# Rate limiting — formato slowapi "N/period" (second|minute|hour).
# Establecer RATE_LIMIT_ENABLED=false en entornos de test para no falsear assertions.
RATE_LIMIT_ENABLED=true
RATE_LIMIT_LOGIN=10/minute
RATE_LIMIT_REGISTER=5/minute
RATE_LIMIT_REFRESH=30/minute

# Sentry observability (optional). Leave empty to disable.
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.0
SENTRY_PROFILES_SAMPLE_RATE=0.0
