# Nombre del proyecto
PROJECT_NAME=Atlas Finance

# Prefijo para las rutas de la API
API_V1_PREFIX=/api/v1

# URL de la base de datos
DATABASE_URL=postgresql+psycopg://atlas:atlas@db:5432/atlas_finance

# Clave secreta para firmar los tokens JWT
SECRET_KEY=super-secret-change-me

# Algoritmo utilizado para los tokens JWT
ALGORITHM=HS256

# Tiempo de expiración del token de acceso (en minutos)
ACCESS_TOKEN_EXPIRE_MINUTES=120

# Tiempo de expiración del refresh token (en minutos)
REFRESH_TOKEN_EXPIRE_MINUTES=1440

# URL de la API de tasas de cambio
EXCHANGE_RATE_API_URL=https://api.exchangerate.host/

# Moneda predeterminada
DEFAULT_CURRENCY=COP

# Origenes permitidos para CORS (separados por coma)
BACKEND_CORS_ORIGINS=http://localhost:8502,http://127.0.0.1:8502,http://localhost:5173,http://127.0.0.1:5173