# URL base de la API del backend. Al tener prefijo VITE_ queda expuesta en el
# navegador como import.meta.env.VITE_API_URL. Debe coincidir con el puerto
# y prefijo del servicio backend (docker-compose: 8000, prefijo: /api/v1).
VITE_API_URL=http://localhost:8000/api/v1

# Duración global de todos los toasts en milisegundos.
VITE_TOAST_DURATION_MS=8000
