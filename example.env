# =================================================================
# Variables de entorno raíz — usadas por los servicios: db, frontend
# Copiar como .env en la raíz del repositorio.
#
# IMPORTANTE: Si cambias POSTGRES_USER, POSTGRES_PASSWORD o POSTGRES_DB,
# debes actualizar también DATABASE_URL en backend/.env para que coincidan.
# =================================================================

# ── PostgreSQL (db service) ──────────────────────────────────────
# Credenciales del motor de base de datos PostgreSQL.
POSTGRES_DB=atlas_finance
POSTGRES_USER=atlas
POSTGRES_PASSWORD=atlas

# ── Frontend (frontend service) ──────────────────────────────────
# Habilita polling de archivos en sistemas sin inotify (ej. Docker en Windows).
CHOKIDAR_USEPOLLING=true
# URL base de la API consumida por el frontend. Debe apuntar al servicio backend.
VITE_API_URL=http://localhost:8000/api/v1
